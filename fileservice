using System.IO;
using System.Text.Json;

public class FileService
{
    public static void Save(StudentManager manager, string path = "data.json")
    {
        string json = JsonSerializer.Serialize(manager);
        File.WriteAllText(path, json);
    }

    public static StudentManager Load(string path = "data.json")
    {
        if (!File.Exists(path))
            return new StudentManager();

        string json = File.ReadAllText(path);
        return JsonSerializer.Deserialize<StudentManager>(json);
    }
}
